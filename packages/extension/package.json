{
  "name": "builtin.prettier",
  "version": "0.0.0-dev",
  "description": "Prettier extension for Lvce Editor",
  "main": "dist/prettierMain.js",
  "dependencies": {
    "ignore": "^7.0.5"
  },
  "scripts": {
    "test": "node --unhandled-rejections=warn --experimental-vm-modules ../../node_modules/jest/bin/jest.js --detectOpenHandles --forceExit",
    "test:watch": "node --unhandled-rejections=warn --experimental-vm-modules ../../node_modules/jest/bin/jest.js --watch"
  },
  "author": "Lvce Editor",
  "license": "MIT",
  "type": "module",
  "jest": {
    "injectGlobals": false,
    "extensionsToTreatAsEsm": [
      ".ts"
    ],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "useESM": true
        }
      ]
    }
  },
  "devDependencies": {
    "@lvce-editor/api": "^8.33.0",
    "@lvce-editor/rpc-registry": "^9.27.0",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11"
  }
}
