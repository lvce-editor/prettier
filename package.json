{
  "name": "builtin.prettier-monorepo",
  "version": "0.0.0-dev",
  "description": "",
  "type": "module",
  "scripts": {
    "build": "node packages/build/src/build.js",
    "build:extension": "node packages/build/src/build-extension.js",
    "dev": "node packages/build/src/dev.js",
    "e2e": "cd packages/e2e && npm run e2e",
    "e2e:headless": "cd packages/e2e && npm run e2e:headless",
    "postinstall": "lerna bootstrap --ci",
    "test": "lerna run test",
    "test:watch": "node --unhandled-rejections=warn --experimental-vm-modules ./node_modules/jest/bin/jest.js --watch",
    "type-check": "tsc -b"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@lerna/legacy-package-management": "^8.2.4",
    "@lvce-editor/api": "^8.26.0",
    "@lvce-editor/eslint-config": "^12.4.0",
    "@lvce-editor/server": "0.84.1",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@types/node": "^25.9.3",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "jest": "^30.4.2",
    "lerna": "^8.2.3",
    "prettier": "^4.0.0-alpha.10",
    "rollup": "^4.62.0",
    "rollup-plugin-esbuild": "^6.2.1",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true
  }
