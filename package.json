{
  "name": "builtin.prettier-monorepo",
  "version": "0.0.0-dev",
  "description": "Prettier extension monorepo for Lvce Editor",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "node packages/build/src/build.ts",
    "build:extension": "node packages/build/src/build-extension.ts",
    "dev": "node packages/build/src/dev.ts",
    "e2e": "npm run e2e --workspace=packages/e2e",
    "e2e:headless": "npm run e2e:headless --workspace=packages/e2e",
    "format": "prettier --write .",
    "lint": "eslint . && prettier --check .",
    "test": "npm test --workspaces --if-present",
    "test:watch": "npm run test:watch --workspace=packages/extension",
    "type-check": "tsc -b"
  },
  "author": "Lvce Editor",
  "license": "MIT",
  "devDependencies": {
    "@lvce-editor/api": "^8.53.1",
    "@lvce-editor/eslint-config": "^17.1.0",
    "@lvce-editor/server": "0.91.21",
    "@types/node": "^26.1.1",
    "eslint": "^10.7.0",
    "jest": "^30.4.2",
    "prettier": "^4.0.0-alpha.10",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true
  }
}
